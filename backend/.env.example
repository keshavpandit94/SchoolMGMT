PORT=5000

# MongoDB Atlas Cloud Database URI
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxx.mongodb.net/school_mgmt?retryWrites=true&w=majority

JWT_SECRET=supersecretjwtkey12345!

# Resend HTTPS Email API (Get free key at https://resend.com)
RESEND_API_KEY=re_your_resend_api_key_here
EMAIL_FROM=onboarding@resend.dev

# Cloudinary Image Storage Credentials (Get free account at https://cloudinary.com)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

CLIENT_URL=http://localhost:5173
